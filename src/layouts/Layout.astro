                </svg>
              </a>
            </div>
          </div>

          <!-- Services Column -->
          <div class="footer-col">
            <h4 class="footer-col-title">Services</h4>
            <ul class="footer-links">
              <li><a href="/services#brand-identity">Brand Identity & Strategy</a></li>
              <li><a href="/services#graphic-design">Graphic Design</a></li>
              <li><a href="/services#motion">Motion Graphics</a></li>
              <li><a href="/services#video">Video Creation & Editing</a></li>
              <li><a href="/services#photography">Photography</a></li>
              <li><a href="/services#events">Live Events & Livestreaming</a></li>
              <li><a href="/services#social">Social Media Campaigns</a></li>
            </ul>
          </div>

          <!-- Company Column -->
          <div class="footer-col">
            <h4 class="footer-col-title">Company</h4>
            <ul class="footer-links">
              <li><a href="/services#web">Web Design & Dev</a></li>
              <li><a href="/services#ai">AI Agents & Automation</a></li>
              <li><a href="/services#education">Education & Training</a></li>
              <li><a href="/portfolio">Portfolio</a></li>
              <li><a href="/showcase">Showcase</a></li>
              <li><a href="/updates">Updates</a></li>
            </ul>
          </div>

          <!-- Contact Column -->
          <div class="footer-col">
            <h4 class="footer-col-title">Contact</h4>
            <ul class="footer-links">
              <li><a href="/contact">Get In Touch</a></li>
              <li><a href="mailto:thekoggmedia@gmail.com">thekoggmedia@gmail.com</a></li>
              <li><a href="https://wa.me/2348139200352" target="_blank">WhatsApp Us</a></li>
              <li><a href="https://wa.me/c/2348139200352" target="_blank">WhatsApp Catalogue</a></li>
            </ul>
            <div class="footer-newsletter">
              <p class="newsletter-label">Get updates in your inbox</p>
              <form class="newsletter-form" id="newsletter-form">
                <input
                  type="email"
                  placeholder="your@email.com"
                  class="newsletter-input"
                  id="newsletter-email"
                  required
                />
                <button type="submit" class="newsletter-btn">→</button>
              </form>
              <p class="newsletter-msg" id="newsletter-msg"></p>
            </div>
            <div class="footer-tagline-box">
              <span class="teal-line"></span>
              <p class="philosophy-text">
                "Beyond the first perception —<br/>into lasting resonance."
