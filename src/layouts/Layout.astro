      <div class="container">
        <div class="footer-top">

          <!-- Brand Column -->
          <div class="footer-brand">
            <img src="/logo-light.png" alt="KOGG MEDIA" class="footer-logo" />
            <p class="footer-tagline">Facilitating the Second Hearing</p>
            <p class="footer-desc">
              A creative-tech agency engineering resonance for brands
              through design, technology, and storytelling.
            </p>
            <div class="social-links">
              <a href="https://www.instagram.com/thekoggmedia" target="_blank" rel="noopener" class="social-link" aria-label="Instagram">
