---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'KOGG MEDIA — Facilitating the Second Hearing',
  description = 'KOGG MEDIA is a creative-tech agency delivering brand identity, design, motion, video, AI systems, live events, and digital solutions. Facilitating the Second Hearing.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#00B4B4" />

    <!-- Open Graph (for social media sharing) -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.jpg" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- Fonts preload -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <title>{title}</title>
  </head>

  <body>
    <!-- Navigation -->
    <nav id="navbar">
      <div class="nav-container">

        <!-- Logo -->
        <a href="/" class="nav-logo">
          <img src="/logo-light.png" alt="KOGG MEDIA" class="logo-img" />
        </a>

        <!-- Desktop Navigation Links -->
        <ul class="nav-links">
          <li><a href="/" class="nav-link">Home</a></li>
          <li><a href="/services" class="nav-link">Services</a></li>
          <li><a href="/portfolio" class="nav-link">Portfolio</a></li>
          <li><a href="/showcase" class="nav-link">Showcase</a></li>
          <li><a href="/updates" class="nav-link">Updates</a></li>
          <li><a href="/contact" class="nav-link nav-cta">Get In Touch</a></li>
        </ul>

        <!-- Mobile Hamburger -->
        <button class="hamburger" id="hamburger" aria-label="Toggle menu">
          <span></span>
          <span></span>
          <span></span>
        </button>

      </div>

      <!-- Mobile Menu -->
      <div class="mobile-menu" id="mobile-menu">
        <ul class="mobile-links">
          <li><a href="/" class="mobile-link">Home</a></li>
          <li><a href="/services" class="mobile-link">Services</a></li>
          <li><a href="/portfolio" class="mobile-link">Portfolio</a></li>
          <li><a href="/showcase" class="mobile-link">Showcase</a></li>
          <li><a href="/updates" class="mobile-link">Updates</a></li>
          <li><a href="/contact" class="mobile-link">Get In Touch</a></li>
        </ul>
      </div>
    </nav>

    <!-- Page Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="footer">
      <div class="container">

        <!-- Footer Top -->
        <div class="footer-top">

          <!-- Brand Column -->
          <div class="footer-brand">
            <img src="/logo-light.png" alt="KOGG MEDIA" class="footer-logo" />
            <p class="footer-tagline">Facilitating the Second Hearing</p>
            <p class="footer-desc">
              A creative-tech agency engineering resonance for brands
              through design, technology, and storytelling.
            </p>
            <!-- Social Links -->
            <div class="social-links">
              <a href="#" class="social-link" aria-label="Instagram">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>
              </a>
              <a href="#" class="social-link" aria-label="LinkedIn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
              </a>
              <a href="#" class="social-link" aria-label="YouTube">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.54C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor" stroke="none"/></svg>
              </a>
              <a href="#" class="social-link" aria-label="Behance">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22 7h-7V5h7v2zm1.726 10c-.442 1.297-2.029 3-5.101 3-3.074 0-5.564-1.729-5.564-5.675 0-3.91 2.325-5.92 5.466-5.92 3.082 0 4.964 1.782 5.375 4.426.078.506.109 1.188.095 2.14H15.97c.13 3.211 3.483 3.312 4.588 2.029H23.726zm-7.726-3h3.543c-.073-1.77-1.339-2.021-1.8-2.021-.475 0-1.618.27-1.743 2.021zm-10.618 3h-3.38V5h3.916c4.973.173 4.979 6.713 0 7h-.536zm-3.38-3h3.38c2.145 0 2.145-4 0-4h-3.38v4z"/></svg>
              </a>
            </div>
          </div>

          <!-- Services Column -->
          <div class="footer-col">
            <h4 class="footer-col-title">Services</h4>
            <ul class="footer-links">
              <li><a href="/services#brand-identity">Brand Identity & Strategy</a></li>
              <li><a href="/services#graphic-design">Graphic Design</a></li>
              <li><a href="/services#motion">Motion Graphics</a></li>
              <li><a href="/services#video">Video Creation & Editing</a></li>
              <li><a href="/services#photography">Photography</a></li>
              <li><a href="/services#events">Live Events & Livestreaming</a></li>
            </ul>
          </div>

          <!-- More Services Column -->
          <div class="footer-col">
            <h4 class="footer-col-title">More</h4>
            <ul class="footer-links">
              <li><a href="/services#social">Social Media Campaigns</a></li>
              <li><a href="/services#web">Web Design & Development</a></li>
              <li><a href="/services#ai">AI Agents & Automation</a></li>
              <li><a href="/services#education">Education & Training</a></li>
              <li><a href="/portfolio">Portfolio</a></li>
              <li><a href="/updates">Updates</a></li>
            </ul>
          </div>

          <!-- Contact Column -->
          <div class="footer-col">
            <h4 class="footer-col-title">Contact</h4>
            <ul class="footer-links">
              <li><a href="/contact">Get In Touch</a></li>
              <li><a href="mailto:hello@koggemedia.com">hello@koggemedia.com</a></li>
            </ul>
            <div class="footer-tagline-box">
              <span class="teal-line"></span>
              <p class="philosophy-text">
                "Beyond the first perception — into lasting resonance."
              </p>
            </div>
          </div>

        </div>

        <!-- Footer Bottom -->
        <div class="footer-bottom">
          <p class="footer-copy">
            &copy; {new Date().getFullYear()} KOGG MEDIA. All rights reserved.
          </p>
          <p class="footer-hash">#Facilitating_the_Second_Hearing</p>
        </div>

      </div>
    </footer>

  </body>
</html>

<!-- ══════════════════════════════════
     NAVBAR & FOOTER STYLES
══════════════════════════════════ -->
<style>
  /* ── NAVBAR ── */
  #navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(10, 22, 40, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0, 180, 180, 0.15);
    transition: all 0.3s ease;
  }

  #navbar.scrolled {
    background: rgba(10, 22, 40, 0.99);
    border-bottom-color: rgba(0, 180, 180, 0.3);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .logo-img {
    height: 38px;
    width: auto;
    object-fit: contain;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
  }

  .nav-link {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    color: rgba(255,255,255,0.8);
    text-decoration: none;
    padding: 0.5rem 0.9rem;
    border-radius: 4px;
    transition: all 0.3s ease;
    letter-spacing: 0.01em;
  }

  .nav-link:hover {
    color: #00B4B4;
    background: rgba(0, 180, 180, 0.08);
  }

  .nav-cta {
    background: #00B4B4;
    color: #ffffff !important;
    padding: 0.5rem 1.25rem;
    border-radius: 4px;
    font-weight: 600;
    margin-left: 0.5rem;
  }

  .nav-cta:hover {
    background: transparent !important;
    color: #00B4B4 !important;
    border: 1px solid #00B4B4;
    box-shadow: 0 0 20px rgba(0, 180, 180, 0.3);
  }

  /* ── HAMBURGER ── */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: #ffffff;
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .hamburger.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }
  .hamburger.active span:nth-child(2) {
    opacity: 0;
  }
  .hamburger.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  /* ── MOBILE MENU ── */
  .mobile-menu {
    display: none;
    background: rgba(10, 22, 40, 0.98);
    border-top: 1px solid rgba(0, 180, 180, 0.15);
    padding: 1rem 1.5rem 2rem;
  }

  .mobile-menu.open {
    display: block;
  }

  .mobile-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobile-link {
    display: block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    padding: 0.75rem 0.5rem;
    border-bottom: 1px solid rgba(0, 180, 180, 0.1);
    transition: color 0.3s ease;
  }

  .mobile-link:hover {
    color: #00B4B4;
  }

  /* ── FOOTER ── */
  .footer {
    background: #0A1628;
    color: rgba(255,255,255,0.7);
    padding: 5rem 0 0;
    margin-top: 5rem;
    border-top: 1px solid rgba(0, 180, 180, 0.2);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 4rem;
  }

  .footer-logo {
    height: 36px;
    width: auto;
    margin-bottom: 1rem;
    filter: brightness(1);
  }

  .footer-tagline {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: #00B4B4;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .footer-desc {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .social-links {
    display: flex;
    gap: 0.75rem;
  }

  .social-link {
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 180, 180, 0.1);
    border: 1px solid rgba(0, 180, 180, 0.2);
    border-radius: 4px;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .social-link:hover {
    background: #00B4B4;
    border-color: #00B4B4;
    color: #ffffff;
    transform: translateY(-3px);
  }

  .footer-col-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    color: #ffffff;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-links a {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .footer-links a:hover {
    color: #00B4B4;
  }

  .footer-tagline-box {
    margin-top: 1.5rem;
    padding: 1rem;
    background: rgba(0, 180, 180, 0.05);
    border-left: 3px solid #00B4B4;
  }

  .philosophy-text {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    font-style: italic;
    line-height: 1.6;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 1.5rem 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-copy {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.4);
  }

  .footer-hash {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.8rem;
    color: #00B4B4;
    letter-spacing: 0.05em;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .nav-links { display: none; }
    .hamburger { display: flex; }

    .footer-top {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>

<!-- ══════════════════════════════════
     NAVBAR SCROLL & MOBILE MENU JS
══════════════════════════════════ -->
<script>
  // Scroll effect on navbar
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  });

  // Mobile menu toggle
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');

  hamburger?.addEventListener('click', () => {
    hamburger.classList.toggle('active');
    mobileMenu?.classList.toggle('open');
  });

  // Close mobile menu when a link is clicked
  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      hamburger?.classList.remove('active');
      mobileMenu?.classList.remove('open');
    });
  });
</script>