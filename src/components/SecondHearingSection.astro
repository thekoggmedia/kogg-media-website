---
// SecondHearingSection.astro
const stages = [
  {
    num: "01",
    title: "The First Hearing",
    desc: "The initial encounter. The first scroll-stop. The first impression. The stage most focus on — and stop at.",
    color: "#E2E8F0",
    textColor: "#0A1628",
  },
  {
    num: "02",
    title: "The Resonance",
    desc: "Emotional and cognitive processing after the encounter. Where quality determines whether the brand sticks or vanishes.",
    color: "#00B4B4",
    textColor: "#ffffff",
  },
  {
    num: "03",
    title: "The Second Hearing",
    desc: "Unprompted recall. A brand remembered without a trigger. Referenced in conversation. Sought out voluntarily.",
    color: "#007A7A",
    textColor: "#ffffff",
  },
  {
    num: "04",
    title: "The Echo",
    desc: "Sustained resonance that builds over time into brand loyalty, trust, and authority. The compound effect of consistent quality.",
    color: "#0A1628",
    textColor: "#ffffff",
  },
];
---

<section class="second-hearing-section" id="philosophy">

  <!-- Left: Dark philosophy panel -->
  <div class="sh-left">
    <div class="sh-left-inner">
      <span class="section-tag">Our Philosophy</span>
      <h2 class="sh-heading">
        Facilitating the<br/>
        <span class="sh-heading-teal">Second Hearing</span>
      </h2>
      <p class="sh-body">
        We don't just help brands communicate.
        We engineer the resonance that makes them
        impossible to forget.
      </p>
      <blockquote class="sh-quote">
        "Beyond the first perception —<br/>
        into lasting resonance."
      </blockquote>
      <div class="sh-tagline">
        <span class="teal-line"></span>
        #Facilitating_the_Second_Hearing
      </div>
      <a href="/contact" class="btn-primary" style="margin-top: 2rem; display: inline-flex;">
        Start Your Echo
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

  <!-- Right: 4 stages -->
  <div class="sh-right">
    {stages.map((stage) => (
      <div
        class="sh-stage"
        style={`background: ${stage.color}; color: ${stage.textColor};`}
      >
        <span class="sh-stage-num"
          style={`color: ${stage.textColor === '#ffffff' ? 'rgba(255,255,255,0.3)' : 'rgba(10,22,40,0.2)'};`}
        >
          {stage.num}
        </span>
        <div>
          <h3 class="sh-stage-title" style={`color: ${stage.textColor};`}>
            {stage.title}
          </h3>
          <p class="sh-stage-desc"
            style={`color: ${stage.textColor === '#ffffff' ? 'rgba(255,255,255,0.7)' : 'rgba(10,22,40,0.65)'};`}
          >
            {stage.desc}
          </p>
        </div>
      </div>
    ))}
  </div>

</section>

<style>
  .second-hearing-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 600px;
  }

  /* Left panel */
  .sh-left {
    background: #0A1628;
    display: flex;
    align-items: center;
    padding: 5rem;
  }

  .sh-left-inner {
    max-width: 480px;
  }

  .sh-heading {
    font-family: 'Exo 2', 'Space Grotesk', sans-serif;
    font-size: clamp(2.2rem, 3.5vw, 3rem);
    font-weight: 900;
    color: #ffffff;
    line-height: 1.15;
    margin: 0.75rem 0 1.25rem;
    letter-spacing: 0.03em;
  }

  .sh-heading-teal {
    color: #00B4B4;
  }

  .sh-body {
    font-size: 1rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .sh-quote {
    font-size: 1rem;
    color: rgba(255,255,255,0.7);
    font-style: italic;
    border-left: 3px solid #00B4B4;
    padding: 0.75rem 1rem;
    background: rgba(0,180,180,0.06);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .sh-tagline {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.78rem;
    color: #00B4B4;
    letter-spacing: 0.08em;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .sh-tagline .teal-line {
    margin-bottom: 0;
    width: 30px;
  }

  /* Right panel: 4 stages */
  .sh-right {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
  }

  .sh-stage {
    position: relative;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.5rem;
    overflow: hidden;
    transition: all 0.3s ease;
    cursor: default;
  }

  .sh-stage:hover {
    filter: brightness(1.08);
  }

  .sh-stage-num {
    font-family: 'Exo 2', sans-serif;
    font-size: 3.5rem;
    font-weight: 900;
    line-height: 1;
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    letter-spacing: -0.02em;
  }

  .sh-stage-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
  }

  .sh-stage-desc {
    font-size: 0.82rem;
    line-height: 1.6;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .second-hearing-section {
      grid-template-columns: 1fr;
    }

    .sh-left { padding: 3rem 2rem; }
    .sh-left-inner { max-width: 100%; }
  }

  @media (max-width: 768px) {
    .sh-right {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }

    .sh-stage { padding: 2rem; }
  }
</style>