---

<section class="services-section section" id="services">
  <div class="container">

    <div class="services-header">
      <span class="section-tag">What We Do</span>
      <h2 class="section-title">Our Services</h2>
      <p class="section-subtitle">
        11 service areas. One philosophy. Every deliverable engineered
        to create the Second Hearing for your brand.
      </p>
    </div>

    <div class="services-grid">
      {services.map((service) => (
        <a href={service.href} class="service-card">
          <div class="service-num">{service.num}</div>
          <div class="service-icon" set:html={service.icon} />
          <h3 class="service-title">{service.title}</h3>
          <p class="service-desc">{service.desc}</p>
          <div class="service-arrow">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </a>
      ))}
    </div>

    <div class="services-cta">
      <a href="/services" class="btn-outline">
        View All Services
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

  </div>
</section>

<style>
  .services-section {
    background: #ffffff;
    padding: 7rem 1.5rem;
  }

  .services-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .services-header .section-subtitle {
    margin: 0 auto;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .service-card {
    position: relative;
    background: #ffffff;
    border: 1px solid #E2E8F0;
    border-radius: 8px;
    padding: 2rem;
    text-decoration: none;
    transition: all 0.3s ease;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 3px;
    background: #00B4B4;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }

  .service-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0,180,180,0.03) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .service-card:hover {
    border-color: #00B4B4;
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0,180,180,0.1);
  }

  .service-card:hover::before { transform: scaleX(1); }
  .service-card:hover::after  { opacity: 1; }

  .service-num {
    font-family: 'Exo 2', 'Space Grotesk', sans-serif;
    font-size: 0.7rem;
    font-weight: 800;
    color: #00B4B4;
    letter-spacing: 0.1em;
    opacity: 0.7;
  }

  .service-icon {
    color: #00B4B4;
    margin-bottom: 0.25rem;
  }

  .service-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #0A1628;
    line-height: 1.35;
    margin: 0;
  }

  .service-desc {
    font-size: 0.88rem;
    color: #4A5568;
    line-height: 1.7;
    flex: 1;
  }

  .service-arrow {
    color: #00B4B4;
    opacity: 0;
    transform: translateX(-5px);
    transition: all 0.3s ease;
    align-self: flex-end;
  }

  .service-card:hover .service-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .services-cta {
    text-align: center;
    margin-top: 3rem;
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>