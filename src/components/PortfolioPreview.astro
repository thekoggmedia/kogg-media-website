---
const projects = [
  {
    title: "Brand Identity & Strategy",
    category: "Branding",
    tag: "Identity",
    desc: "Logo design, brand guidelines, visual identity systems built for recognition and recall.",
    icon: "◎",
    accent: "#00B4B4",
  },
  {
    title: "Motion Graphics Reel",
    category: "Motion & Animation",
    tag: "Motion",
    desc: "Animated brand content and motion graphics that reinforce memory through rhythm and flow.",
    icon: "▶",
    accent: "#007A7A",
  },
  {
    title: "Digital Campaign Design",
    category: "Social Media",
    tag: "Campaign",
    desc: "Content systems crafted to cut through noise and remain present in the audience's mind.",
    icon: "◈",
    accent: "#0D2040",
  },
  {
    title: "Web Design & Development",
    category: "Web & Digital",
    tag: "Web",
    desc: "Digital experiences built for maximum engagement, clarity, and return visits.",
    icon: "⬡",
    accent: "#00B4B4",
  },
  {
    title: "Live Event Production",
    category: "Events",
    tag: "Live",
    desc: "Live experiences designed to extend beyond the moment and continue to resonate.",
    icon: "◉",
    accent: "#007A7A",
  },
  {
    title: "Photography & Visual Capture",
    category: "Photography",
    tag: "Photo",
    desc: "Authentic visual capture that humanises brands and deepens audience connection.",
    icon: "⬤",
    accent: "#0D2040",
  },
];
---

<section class="portfolio-section" id="portfolio">
  <div class="container">

    <div class="portfolio-header">
      <div>
        <span class="section-tag">Our Work</span>
        <h2 class="section-title">Selected Projects</h2>
        <p class="section-subtitle">
          Work that doesn't just get noticed — work that echoes.
        </p>
      </div>
      <a href="https://www.behance.net/thekoggmedia" target="_blank" rel="noopener" class="btn-outline portfolio-header-btn">
        Full Portfolio on Behance
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
    </div>

    <div class="portfolio-grid">
      {projects.map((project, i) => (
        <a href="https://www.behance.net/thekoggmedia" target="_blank" rel="noopener" class={`pcard ${i === 0 || i === 3 ? 'pcard--wide' : ''}`}>
          <div class="pcard-top" style={`border-top: 3px solid ${project.accent};`}>
            <div class="pcard-icon-wrap" style={`background: ${project.accent}18; color: ${project.accent};`}>
              <span class="pcard-icon">{project.icon}</span>
            </div>
            <span class="pcard-tag" style={`color: ${project.accent}; background: ${project.accent}15; border: 1px solid ${project.accent}30;`}>
              {project.tag}
            </span>
          </div>
          <div class="pcard-body">
            <p class="pcard-category">{project.category}</p>
            <h3 class="pcard-title">{project.title}</h3>
            <p class="pcard-desc">{project.desc}</p>
          </div>
          <div class="pcard-footer">
            <span class="pcard-link">
              View on Behance
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <div class="behance-strip">
      <div class="behance-strip-left">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="#1769FF"><path d="M22 7h-7V5h7v2zm1.726 10c-.442 1.297-2.029 3-5.101 3-3.074 0-5.564-1.729-5.564-5.675 0-3.91 2.325-5.92 5.466-5.92 3.082 0 4.964 1.782 5.375 4.426.078.506.109 1.188.095 2.14H15.97c.13 3.211 3.483 3.312 4.588 2.029H23.726zm-7.726-3h3.543c-.073-1.77-1.339-2.021-1.8-2.021-.475 0-1.618.27-1.743 2.021zm-10.618 3h-3.38V5h3.916c4.973.173 4.979 6.713 0 7h-.536zm-3.38-3h3.38c2.145 0 2.145-4 0-4h-3.38v4z"/></svg>
        <div>
          <p class="behance-strip-title">See our complete work on Behance</p>
          <p class="behance-strip-url">behance.net/thekoggmedia</p>
        </div>
      </div>
      <a href="https://www.behance.net/thekoggmedia" target="_blank" rel="noopener" class="btn-primary">
        Open Behance Profile
      </a>
    </div>

  </div>
</section>

<style>
  .portfolio-section {
    background: #F8FAFB;
    padding: 7rem 1.5rem;
  }

  .portfolio-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .portfolio-header-btn {
    flex-shrink: 0;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .pcard {
    background: #ffffff;
    border: 1px solid #E2E8F0;
    border-radius: 10px;
    padding: 1.75rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: all 0.3s ease;
    overflow: hidden;
  }

  .pcard--wide {
    grid-column: span 2;
  }

  .pcard:hover {
    border-color: #00B4B4;
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0, 180, 180, 0.1);
  }

  .pcard-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.25rem;
  }

  .pcard-icon-wrap {
    width: 44px;
    height: 44px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pcard-icon {
    font-size: 1.2rem;
    line-height: 1;
  }

  .pcard-tag {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.25rem 0.65rem;
    border-radius: 100px;
  }

  .pcard-body {
    flex: 1;
  }

  .pcard-category {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    color: #94A3B8;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.35rem;
  }

  .pcard-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: #0A1628;
    line-height: 1.3;
    margin: 0 0 0.6rem;
  }

  .pcard-desc {
    font-size: 0.86rem;
    color: #4A5568;
    line-height: 1.7;
  }

  .pcard-footer {
    border-top: 1px solid #F1F5F9;
    padding-top: 0.75rem;
  }

  .pcard-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    color: #00B4B4;
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.3s ease;
  }

  .pcard:hover .pcard-link {
    opacity: 1;
    transform: translateX(0);
  }

  .behance-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    background: #ffffff;
    border: 1px solid #E2E8F0;
    border-radius: 10px;
    padding: 1.5rem 2rem;
    flex-wrap: wrap;
  }

  .behance-strip-left {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .behance-strip-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: #0A1628;
    margin-bottom: 0.15rem;
  }

  .behance-strip-url {
    font-size: 0.82rem;
    color: #94A3B8;
  }

  @media (max-width: 900px) {
    .portfolio-grid { grid-template-columns: repeat(2, 1fr); }
    .pcard--wide { grid-column: span 2; }
  }

  @media (max-width: 600px) {
    .portfolio-grid { grid-template-columns: 1fr; }
    .pcard--wide { grid-column: span 1; }
    .portfolio-header { flex-direction: column; align-items: flex-start; }
    .behance-strip { flex-direction: column; align-items: flex-start; }
  }
</style>