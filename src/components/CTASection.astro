---
// CTASection.astro
---

<section class="cta-section">
  <div class="cta-bg-pattern"></div>
  <div class="cta-orb"></div>

  <div class="container">
    <div class="cta-inner">
      <span class="section-tag" style="color: rgba(0,180,180,0.8);">
        Ready to Resonate?
      </span>
      <h2 class="cta-heading">
        Ready for the<br/>
        <span class="cta-heading-teal">Second Hearing?</span>
      </h2>
      <p class="cta-sub">
        Let's build something that doesn't just get noticed —
        something that echoes. Start the conversation today.
      </p>
      <div class="cta-btns">
        <a href="/contact" class="btn-primary">
          Start a Project
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="https://wa.me/2348139200352" target="_blank" rel="noopener" class="btn-secondary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          WhatsApp Us Now
        </a>
        <a href="https://wa.me/c/2348139200352" target="_blank" rel="noopener" class="cta-catalogue-btn">
          View Our Catalogue
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background: #0A1628;
    padding: 8rem 1.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-top: 1px solid rgba(0,180,180,0.15);
  }

  .cta-bg-pattern {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,180,180,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,180,180,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .cta-orb {
    position: absolute;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(0,180,180,0.1) 0%, transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    filter: blur(40px);
  }

  .cta-inner {
    position: relative;
    z-index: 2;
    max-width: 700px;
    margin: 0 auto;
  }

  .cta-heading {
    font-family: 'Exo 2', 'Space Grotesk', sans-serif;
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 900;
    color: #ffffff;
    line-height: 1.1;
    letter-spacing: 0.04em;
    margin: 0.75rem 0 1.25rem;
  }

  .cta-heading-teal {
    color: #00B4B4;
    -webkit-text-stroke: 1px #00B4B4;
    text-shadow: 0 0 40px rgba(0,180,180,0.4);
  }

  .cta-sub {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.8;
    margin-bottom: 2.5rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    align-items: center;
  }

  .cta-catalogue-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .cta-catalogue-btn:hover {
    color: #00B4B4;
  }
</style>